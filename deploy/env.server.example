# =============================================================================
# PitchCopyTrade — серверная конфигурация
# Скопировать в .env.server и заполнить обязательные поля (помечены FILL_ME)
# =============================================================================

APP_NAME=PitchCopyTrade
APP_ENV=staging
APP_HOST=0.0.0.0
APP_PORT=8000

# Длинная случайная строка, минимум 32 символа — ОБЯЗАТЕЛЬНО
APP_SECRET_KEY=CHANGE_ME_TO_LONG_RANDOM_SECRET

BASE_URL=http://pct.example.ru
ADMIN_BASE_URL=http://pct.example.ru/admin

# -----------------------------------------------------------------------------
# Режим хранения данных
# file — JSON-файлы, без PostgreSQL (для старта без БД)
# db   — PostgreSQL (рекомендуется для production)
# -----------------------------------------------------------------------------
APP_DATA_MODE=db
APP_STORAGE_ROOT=/data/storage

# -----------------------------------------------------------------------------
# Telegram
# -----------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=__FILL_ME__
TELEGRAM_BOT_USERNAME=__FILL_ME__
TELEGRAM_USE_WEBHOOK=false
TELEGRAM_WEBHOOK_SECRET=unused

# -----------------------------------------------------------------------------
# PostgreSQL — обязательно заполнить при APP_DATA_MODE=db
#
# DATABASE_URL — используется приложением (asyncpg через Docker → host.docker.internal)
#
# Формат: postgresql+asyncpg://user:password@host:port/dbname
# При подключении из контейнера к локальному postgres — host = host.docker.internal
# При подключении из контейнера к postgres в той же docker-сети — host = имя_сервиса
# -----------------------------------------------------------------------------
POSTGRES_DB=pct
POSTGRES_USER=pct
POSTGRES_PASSWORD=__FILL_ME__

# Хост и порт postgres для deploy/migrate.sh (по умолчанию 127.0.0.1:5432)
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432

# URL для приложения внутри контейнера
DATABASE_URL=postgresql+asyncpg://pct:__FILL_ME__@host.docker.internal:5432/pct

# -----------------------------------------------------------------------------
# Docker-сеть
#
# Два режима:
#   DOCKER_NETWORK_EXTERNAL=false — docker-compose создаёт новую сеть pct_net
#   DOCKER_NETWORK_EXTERNAL=true  — docker-compose подключается к существующей сети
#
# Вариант А (standalone-сервер, postgres локально):
#   DOCKER_NETWORK_EXTERNAL=false
#   DOCKER_NETWORK_NAME=pct_net
#   DATABASE_URL=...@host.docker.internal:5432/pct
#
# Вариант Б (сервер с общей docker-сетью, postgres в сети):
#   DOCKER_NETWORK_EXTERNAL=true
#   DOCKER_NETWORK_NAME=ptfin-backend   # имя существующей сети
#   DATABASE_URL=...@postgres_service_name:5432/pct
#   REDIS_URL=redis://redis_service_name:6379/0
# -----------------------------------------------------------------------------
DOCKER_NETWORK_EXTERNAL=false
DOCKER_NETWORK_NAME=pct_net

# -----------------------------------------------------------------------------
# Уведомления (SMTP)
# REDIS_URL остаётся в конфиге для совместимости runtime, но ARQ очередь не используется
# -----------------------------------------------------------------------------
INTERNAL_API_SECRET=__FILL_ME__
REDIS_URL=redis://host.docker.internal:6379/0

SMTP_HOST=relay.ptfin.kz
SMTP_PORT=465
SMTP_SSL=true
SMTP_USER=pct@ptfin.ru
SMTP_PASSWORD=__FILL_ME__
SMTP_FROM=pct@ptfin.ru
SMTP_FROM_NAME=PitchCopyTrade

# -----------------------------------------------------------------------------
# Администратор по умолчанию (создаётся при первом старте в db-режиме)
# -----------------------------------------------------------------------------
ADMIN_TELEGRAM_ID=
ADMIN_EMAIL=

# -----------------------------------------------------------------------------
# Платежи
# stub_manual — ручное подтверждение администратором (MVP)
# tbank       — автоматический T-Bank SBP
# -----------------------------------------------------------------------------
SBP_PROVIDER=stub_manual
SBP_STUB_CONFIRMATION_MODE=manual
TINKOFF_TERMINAL_KEY=unused
TINKOFF_SECRET_KEY=unused

# -----------------------------------------------------------------------------
# Функциональность
# -----------------------------------------------------------------------------
TRIAL_ENABLED=true
PROMO_ENABLED=true
AUTORENEW_ENABLED=true
BASE_TIMEZONE=Europe/Moscow
AUTH_SESSION_TTL_SECONDS=86400
AUTH_SESSION_COOKIE_NAME=pitchcopytrade_session

# -----------------------------------------------------------------------------
# Логирование
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO
LOG_JSON=false
