# =============================================================================
# PitchCopyTrade — sample local env
# Copy to .env and fill the placeholders below.
# =============================================================================

APP_NAME=PitchCopyTrade
APP_ENV=development
APP_HOST=127.0.0.1
APP_PORT=8000

# Длинная случайная строка, минимум 32 символа — ОБЯЗАТЕЛЬНО
APP_SECRET_KEY=__FILL_ME__

BASE_URL=http://127.0.0.1:8000
ADMIN_BASE_URL=http://127.0.0.1:8000/admin

# -----------------------------------------------------------------------------
# Режим хранения данных
# file — JSON-файлы, без PostgreSQL (для старта без БД)
# db   — PostgreSQL (рекомендуется для production)
# -----------------------------------------------------------------------------
APP_DATA_MODE=file
APP_PREVIEW_ENABLED=true
APP_STORAGE_ROOT=storage

# -----------------------------------------------------------------------------
# Telegram
# -----------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=__FILL_ME__
TELEGRAM_BOT_USERNAME=__FILL_ME__
TELEGRAM_USE_WEBHOOK=false
TELEGRAM_WEBHOOK_SECRET=__FILL_ME__

# -----------------------------------------------------------------------------
# PostgreSQL — заполняйте только если APP_DATA_MODE=db
# -----------------------------------------------------------------------------
POSTGRES_DB=pct
POSTGRES_USER=pct
POSTGRES_PASSWORD=__FILL_ME__
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
DATABASE_URL=

# -----------------------------------------------------------------------------
# Уведомления
# -----------------------------------------------------------------------------
INTERNAL_API_SECRET=__FILL_ME__
REDIS_URL=redis://localhost:6379/0

SMTP_HOST=
SMTP_PORT=465
SMTP_SSL=true
SMTP_USER=
SMTP_PASSWORD=__FILL_ME__
SMTP_FROM=
SMTP_FROM_NAME=PitchCopyTrade

# -----------------------------------------------------------------------------
# Администратор по умолчанию (опционально для db-режима)
# -----------------------------------------------------------------------------
ADMIN_TELEGRAM_ID=
ADMIN_EMAIL=

# -----------------------------------------------------------------------------
# Платежи
# -----------------------------------------------------------------------------
SBP_PROVIDER=stub_manual
SBP_STUB_CONFIRMATION_MODE=manual
TINKOFF_TERMINAL_KEY=__FILL_ME__
TINKOFF_SECRET_KEY=__FILL_ME__

# -----------------------------------------------------------------------------
# Функциональность
# -----------------------------------------------------------------------------
TRIAL_ENABLED=true
PROMO_ENABLED=true
AUTORENEW_ENABLED=true
BASE_TIMEZONE=Europe/Moscow
AUTH_SESSION_TTL_SECONDS=86400
AUTH_SESSION_COOKIE_NAME=pitchcopytrade_session

# -----------------------------------------------------------------------------
# Логирование
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO
LOG_JSON=false
